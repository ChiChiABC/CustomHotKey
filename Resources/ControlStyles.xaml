<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="\Resources\Control\Button.xaml"/>
        <ResourceDictionary Source="\Resources\Control\TextBox.xaml"/>
        <ResourceDictionary Source="\Resources\Control\ComboBox.xaml"/>
        <ResourceDictionary Source="\Resources\Control\GroupBox.xaml"/>
        <ResourceDictionary Source="\Resources\Control\CheckBox.xaml"/>
        <ResourceDictionary Source="\Resources\Control\TreeView.xaml"/>
        <ResourceDictionary Source="\Resources\Control\MenuItem.xaml"/>
        <ResourceDictionary Source="\Resources\Control\ScrollBar.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
</ResourceDictionary>