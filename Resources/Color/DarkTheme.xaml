<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window ↓ -->
    <SolidColorBrush Color="#333333" x:Key="Window.DefaultBackground"/>
    <SolidColorBrush Color="#111122" x:Key="Window.DefaultBorderBrush"/>
    <SolidColorBrush Color="#DFDFDF" x:Key="Window.DefaultForeground"/>
    <!-- Control -->
    <SolidColorBrush Color="#555555" x:Key="Control.DefaultBackground"/>
    <SolidColorBrush Color="#232323" x:Key="Control.DefaultBorderBrush"/>
    <SolidColorBrush Color="#DFDFDF" x:Key="Control.DefaultForeground"/>

    <SolidColorBrush Color="#676767" x:Key="Control.DisabledBackground"/>
    <SolidColorBrush Color="#666666" x:Key="Control.DisabledBorderBrush"/>
    <SolidColorBrush Color="#BCBCBC" x:Key="Control.DisabledForeground"/>

    <SolidColorBrush Color="#121212" x:Key="Control.PressedBackground"/>
    <SolidColorBrush Color="#101010" x:Key="Control.PressedBorderBrush"/>

    <SolidColorBrush Color="#363636" x:Key="Control.MouseOverBackground"/>
    <SolidColorBrush Color="#242424" x:Key="Control.MouseOverBorderBrush"/>

</ResourceDictionary>